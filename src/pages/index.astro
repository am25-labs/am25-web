---
export const prerender = true;

import RootLayout from "@/layouts/RootLayout.astro";
import PageDescription from "@/components/PageDescription.astro";
import FeaturedWork from "@/components/home/FeaturedWork.astro";
import Services from "@/components/home/Services.astro";
import { getHome } from "@/lib/plank/fetch";
import RecentEntries from "@/components/home/RecentEntries.astro";

const { quote, services } = await getHome();
---

<RootLayout
  title="AM25 - Design & Web Studio"
  description="We are an independent creative studio."
  image="https://am25.work/og-image.png"
  url="https://am25.work"
>
  <PageDescription description={quote} variant="display" />

  <FeaturedWork />
  <Services services={services} />
  <RecentEntries />
</RootLayout>

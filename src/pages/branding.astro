---
export const prerender = true;

import { Separator } from "@/components/ui/separator";
import Card from "@/components/ui/astro/Card.astro";
import GridContainer from "@/layouts/GridContainer.astro";
import GridFour from "@/layouts/grids/GridFour.astro";
import GridSix from "@/layouts/grids/GridSix.astro";
import RootLayout from "@/layouts/RootLayout.astro";
---

<RootLayout
  title="Our Branding - AM25"
  description="We are an independent creative studio."
  image="https://am25.work/og-image.jpg"
  url="https://am25.work/branding"
  variant="yellow"
>
  <GridContainer>
    <GridSix>
      <div class="col-span-full mb-48">
        <p class="text-4xl md:text-7xl font-bold uppercase">
          We are an independent creative studio.
        </p>
      </div>
    </GridSix>

    <GridFour>
      <div class="col-span-full mb-8">
        <h2 class="text-2xl font-bold uppercase mb-4">Graphic</h2>
        <p class="text-lg">
          Identity, editorial, and digital-first systems built to last beyond
          launch.
        </p>
      </div>
    </GridFour>

    <GridFour>
      <div class="col-span-full mb-16">
        <h2 class="text-2xl font-bold uppercase mb-4">Web-Dev</h2>
        <p class="text-lg">
          Sites and small products. Built lean, maintained honestly, shipped on
          time.
        </p>
      </div>
    </GridFour>

    <Separator className="col-span-full" />

    <GridSix>
      <div class="col-span-full my-32 md:my-48">
        <h2 class="text-3xl md:text-5xl">
          <span class="font-bold">Good taste, meeting the brief.</span> No need to
          be louder.
        </h2>
      </div>
    </GridSix>

    <Separator className="col-span-full" />

    <GridSix>
      <div class="col-span-full my-16">
        <h2 class="text-lg font-bold uppercase mb-8">How we think</h2>

        <p class="text-3xl mb-8">
          Business is important — we’re not going to lie to ourselves, or to
          you, by saying otherwise. Creativity and its exploration are equally
          important.
        </p>

        <p>Both pay the rent. One of them is why we stayed.</p>
      </div>
    </GridSix>

    <Separator className="col-span-full" />

    <GridSix>
      <div class="col-span-full my-16">
        <p class="text-3xl md:text-4xl font-bold uppercase">
          Two forces.<br />One decision at a time.
        </p>
      </div>
    </GridSix>

    <GridFour>
      <div class="col-span-full mb-8">
        <h2 class="text-2xl font-bold uppercase mb-4">Client objectives</h2>
        <p class="text-lg">
          Measurable. Specific. The reason the project exists at all.
        </p>
      </div>
    </GridFour>

    <GridFour>
      <div class="col-span-full mb-16">
        <h2 class="text-2xl font-bold uppercase mb-4">Good taste</h2>
        <p class="text-lg">The part that keeps the work from being ignored.</p>
      </div>
    </GridFour>

    <div class="col-span-full mb-16">
      <h2 class="text-lg font-bold uppercase mb-8">Four working rules</h2>

      <div
        class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border border border-border"
      >
        <Card class="ring-0 min-h-48">
          <div slot="content" class="flex flex-col gap-4 py-4">
            <span class="text-xl font-bold tabular-nums uppercase"
              >01 The brief wins.</span
            >
            <span class="text-lg"
              >Business is important. We're not going to lie to ourselves — or
              to you — by saying otherwise.</span
            >
          </div>
        </Card>
        <Card class="ring-0 min-h-48">
          <div slot="content" class="flex flex-col gap-4 py-4">
            <span class="text-xl font-bold tabular-nums uppercase"
              >02 Less, if less works.</span
            >
            <span class="text-lg"
              >If it looks done without the extra element, it's done. No
              gradients to fill silence.</span
            >
          </div>
        </Card>
        <Card class="ring-0 min-h-48">
          <div slot="content" class="flex flex-col gap-4 py-4">
            <span class="text-xl font-bold tabular-nums uppercase"
              >03 One opinion at a time.</span
            >
            <span class="text-lg"
              >A direction is a decision. We'd rather commit and iterate than
              hedge across three variants.</span
            >
          </div>
        </Card>
        <Card class="ring-0 min-h-48">
          <div slot="content" class="flex flex-col gap-4 py-4">
            <span class="text-xl font-bold tabular-nums uppercase"
              >04 Build it, then ship it.</span
            >
            <span class="text-lg"
              >Design and development in the same room. Handoffs, when they
              happen, are short.</span
            >
          </div>
        </Card>
      </div>
    </div>
  </GridContainer>
</RootLayout>

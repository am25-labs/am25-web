---
import { getEntry, render } from "astro:content";
import GenericContent from "@/layouts/GenericContent.astro";
import GridContainer from "@/layouts/GridContainer.astro";
import RootLayout from "@/layouts/RootLayout.astro";
import Alert from "@/components/ui/astro/Alert.astro";
import Faq from "@/components/about/Faq.astro";

const entry = await getEntry("pages", "about");
if (!entry) return Astro.redirect("/404");
const { Content } = await render(entry);
---

<RootLayout title={`${entry.data.title} | AM25`}>
  <GenericContent title={entry.data.title} quote={entry.data.quote}>
    <Content />

    <a href="/branding">
      <Alert variant="info" class="mt-8">
        <span slot="title">Curious enough?</span>
        <p>Fine. Meet AM25 and see what we actually do.</p>
      </Alert>
    </a>
  </GenericContent>

  <Faq />
</RootLayout>

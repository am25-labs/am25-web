---
import RootLayout from "@/layouts/RootLayout.astro";
import CategoriesFilter from "@/components/content/CategoriesFilter.astro";
import { getWorks } from "@/lib/plank/fetch";

const { data: works } = await getWorks();
const entries = works.map((w) => ({
  id: w.id,
  title: w.title,
  slug: w.slug,
  cover: w.cover,
  categories: w.disciplines,
}));
---

<RootLayout
  title="Work / Cases - AM25"
  description="We are an independent creative studio."
  image="https://am25.work/og-image.png"
  url="https://am25.work/cases"
  variant="yellow"
>
  <div class="col-span-full mb-16 px-4">
    <h1 class="text-6xl md:text-9xl font-bold uppercase">Work / Cases</h1>
  </div>

  {
    entries.length > 0 && (
      <CategoriesFilter entries={entries} baseHref="/cases" />
    )
  }
</RootLayout>

---
import RootLayout from "@/layouts/RootLayout.astro";
import GenericContent from "@/layouts/GenericContent.astro";
import { PlankRenderer } from "@am25/plank-react-renderer";
import { getTerms } from "@/lib/plank/fetch";
import { formatDate } from "@/lib/utils";

const entry = await getTerms();
const title = "Terms & Conditions";
---

<RootLayout title={`${title} | AM25`}>
  <GenericContent
    title={title}
    updated={formatDate(entry.date ?? entry.updated_at)}
  >
    <PlankRenderer content={entry.content} />
  </GenericContent>
</RootLayout>

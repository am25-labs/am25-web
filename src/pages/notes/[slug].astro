---
import RootLayout from "@/layouts/RootLayout.astro";
import { LocalizedNoteTabs } from "@/components/notes/LocalizedNoteTabs";
import { getSingleNote } from "@/lib/plank/fetch";

const { slug } = Astro.params;
const [enNote, esNote] = await Promise.all([
  getSingleNote(slug!),
  getSingleNote(slug!, { locale: "es" }),
]);

const noteForTitle = enNote ?? esNote;
if (!noteForTitle) return Astro.redirect("/notes");
---

<RootLayout title={`${noteForTitle.title} | AM25`} variant="light">
  <LocalizedNoteTabs enNote={enNote} esNote={esNote} client:load />
</RootLayout>

---
import NotePage from "@/layouts/pages/NotePage.astro";
import { getSingleNote } from "@/lib/plank/fetch";

const { slug } = Astro.params;
const [enNote, esNote] = await Promise.all([
  getSingleNote(slug!),
  getSingleNote(slug!, { locale: "es" }),
]);
---

<NotePage enNote={enNote} esNote={esNote} slug={slug!} />

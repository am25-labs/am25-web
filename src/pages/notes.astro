---
import RootLayout from "@/layouts/RootLayout.astro";
import CategoriesFilter from "@/components/content/CategoriesFilter.astro";
import { getNotes } from "@/lib/plank/fetch";

const { data: notes } = await getNotes();
const entries = notes.map((n) => ({
  id: n.id,
  title: n.title,
  slug: n.slug,
  cover: n.cover,
  categories: n.category ? [n.category] : [],
  publishedAt: n.published_at,
  author: n.author,
}));
---

<RootLayout
  title="Notes - AM25"
  description="We are an independent creative studio."
  image="https://am25.work/og-image.jpg"
  url="https://am25.work/notes"
  variant="light"
>
  <div class="col-span-full mb-16 px-4">
    <h1 class="text-6xl md:text-9xl font-bold uppercase">Notes</h1>
  </div>

  {
    entries.length > 0 && (
      <CategoriesFilter entries={entries} baseHref="/notes" />
    )
  }
</RootLayout>

---
import RootLayout from "@/layouts/RootLayout.astro";
import GenericContent from "@/layouts/GenericContent.astro";
import { ProseRenderer } from "@/components/ProseRenderer";
import { getCopyright } from "@/lib/plank/fetch";

const entry = await getCopyright();
const title = "Copyright";
---

<RootLayout title={`${title} | AM25`}>
  <GenericContent title={title}>
    <ProseRenderer content={entry.content} />
  </GenericContent>
</RootLayout>

---
import RootLayout from "@/layouts/RootLayout.astro";
import GenericContent from "@/layouts/GenericContent.astro";
import { PlankRenderer } from "@am25/plank-react-renderer";
import { getCopyright } from "@/lib/plank/fetch";
import { formatDate } from "@/lib/utils";

const entry = await getCopyright();
---

<RootLayout title="Copyright | AM25">
  <GenericContent title="Copyright" updated={formatDate(entry.updated_at)}>
    <PlankRenderer content={entry.content} />
  </GenericContent>
</RootLayout>

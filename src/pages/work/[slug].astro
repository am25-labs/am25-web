---
import RootLayout from "@/layouts/RootLayout.astro";
import WorkHeader from "@/components/work/WorkHeader.astro";
import WorkMeta from "@/components/work/WorkMeta.astro";
import WorkGallery from "@/components/work/WorkGallery.astro";
import { getWorks, getSingleWork } from "@/lib/plank/fetch";

export async function getStaticPaths() {
  const { data: works } = await getWorks();
  return works.map((work) => ({
    params: { slug: work.slug },
  }));
}

const { slug } = Astro.params;
const work = await getSingleWork(slug!);
---

<RootLayout title={`${work.title} | AM25`}>
  <WorkHeader
    title={work.title}
    cover={work.cover}
    description={work.description}
  />

  <WorkMeta
    client={work.client}
    campaign={work.campaign}
    agency={work.agency}
    country={work.country}
    creative={work.creative}
    strategy={work.strategy}
    lead_design={work.lead_design}
    design={work.design}
    copy={work.copy}
    illustration={work.illustration}
    animation={work.animation}
    photo={work.photo}
    developer={work.developer}
    work_team={work.work_team}
  />

  <WorkGallery images={work.images_before} />
  <WorkGallery quote={work.quote} images={work.images_after} />
</RootLayout>

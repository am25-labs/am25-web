---
import { getEntry, render } from "astro:content";
import RootLayout from "@/layouts/RootLayout.astro";
import PageDescription from "@/components/PageDescription.astro";
import ProjectContent from "@/layouts/ProjectContent.astro";

const entry = await getEntry("projects", "gate-idp");
if (!entry) return new Response(null, { status: 404 });
await render(entry);
const { title, icon, description, details, repository, deployment, started, updated, version, documentation, cta } = entry.data;
---

<RootLayout title={`${title} | AM25 Labs`}>
  <PageDescription {description} />

  <ProjectContent
    {title}
    {icon}
    description={entry.body ?? ""}
    {details}
    {repository}
    {deployment}
    {started}
    {updated}
    {version}
    {documentation}
    {cta}
  />
</RootLayout>

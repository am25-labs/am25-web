---
export const prerender = true;

import RootLayout from "@/layouts/RootLayout.astro";
import GenericContent from "@/layouts/GenericContent.astro";
import { ProseRenderer } from "@/components/ProseRenderer";
import { getPrivacy } from "@/lib/plank/fetch";
import { formatDate } from "@/lib/utils";

const entry = await getPrivacy();
const title = "Privacy Policy";
---

<RootLayout
  title={`${title} - AM25`}
  description="We are an independent creative studio."
  image="https://am25.work/og-image.jpg"
  url="https://am25.work/privacy"
>
  <GenericContent
    title={title}
    updated={formatDate(entry.date ?? entry.updated_at)}
  >
    <ProseRenderer content={entry.content} />
  </GenericContent>
</RootLayout>

---
import GridContainer from "@/layouts/GridContainer.astro";
import GridTwo from "@/layouts/grids/GridTwo.astro";
import GridFour from "@/layouts/grids/GridFour.astro";
import { AccordionWrap } from "@/components/ui/custom/Accordion";
import type { FaqItem } from "@/types";

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
const accordionItems = items.map((item) => ({
  label: item.label,
  content: item.description,
}));
---

<GridContainer class="pb-16">
  <GridTwo>
    <span class="col-span-full">
      <h2
        class="text-muted-foreground group-data-[variant=yellow]:text-black text-sm font-bold uppercase"
      >
        Studio FAQs
      </h2>
    </span>
  </GridTwo>

  <GridFour>
    <div class="col-span-full">
      <AccordionWrap items={accordionItems} client:load />
    </div>
  </GridFour>
</GridContainer>

---
import GridContainer from "@/layouts/GridContainer.astro";
import type { Service } from "@/types";

interface Props {
  services: Service[];
}

const { services } = Astro.props;
---

<GridContainer class="pb-24">
  <div class="col-span-full">
    <h2 class="font-bold text-4xl md:text-6xl md:text-center uppercase">
      What we do
    </h2>

    <ul
      class="mt-8 flex list-none flex-col items-start gap-4 p-0 text-left md:flex-row md:justify-center md:gap-24 md:text-center"
    >
      {
        services.map((service) => (
          <li class="text-muted-foreground text-xl md:text-4xl">
            <p>{service.label}</p>
          </li>
        ))
      }
    </ul>
  </div>
</GridContainer>

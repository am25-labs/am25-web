---
import GridContainer from "@/layouts/GridContainer.astro";
import WorkCard from "@/components/WorkCard.astro";
import { getWorks } from "@/lib/strapi/fetchCollection";

const { data } = await getWorks({ onlyFeatured: true });
const works = data.slice(0, 4);
---

<GridContainer class="pb-8">
  <div class="col-span-2">
    <h2 class="text-muted-foreground text-sm font-bold uppercase">
      Featured work
    </h2>
  </div>
</GridContainer>

<GridContainer class="pb-16">
  {
    works.map((work) => (
      <div class="col-span-2">
        <WorkCard
          cover={work.cover?.url ?? ""}
          title={work.title}
          href={`/work/${work.slug}`}
          category={work.disciplines?.[0]?.name ?? ""}
        />
      </div>
    ))
  }
</GridContainer>

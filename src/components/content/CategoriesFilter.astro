---
import GridContainer from "@/layouts/GridContainer.astro";
import NoteCard from "@/components/content/NoteCard.astro";
import WorkCard from "@/components/content/WorkCard.astro";

interface Category {
  id: string;
  title: string;
  slug: string;
}

interface Entry {
  id: string;
  title: string;
  slug: string;
  cover: string | null;
  categories: Category[];
  publishedAt?: string;
  author?: any;
}

interface Props {
  entries: Entry[];
  baseHref: string;
}

const { entries, baseHref } = Astro.props;

const categories = Array.from(
  new Map(entries.flatMap((e) => e.categories).map((c) => [c.id, c])).values(),
);
---

<!-- Mobile -->
<details class="md:hidden border-b mx-4 group">
  <summary
    class="flex items-center justify-between py-3 cursor-pointer list-none"
  >
    <span id="active-label" class="text-sm uppercase font-bold">All</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="transition-transform duration-200 group-open:rotate-180"
    >
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </summary>
  <div class="border-t flex flex-col py-2">
    <button
      class="filter-btn text-sm uppercase py-2 text-left font-bold group-data-[variant=yellow]:text-black group-data-[variant=light]:text-black"
      data-filter="all"
    >
      All
    </button>
    {
      categories.map((c) => (
        <button
          class="filter-btn text-sm py-2 text-left text-muted-foreground group-data-[variant=yellow]:text-black group-data-[variant=light]:text-black"
          data-filter={c.slug}
        >
          {c.title}
        </button>
      ))
    }
  </div>
</details>

<!-- Desktop -->
<div class="hidden md:flex border-b mx-4 py-3 gap-6 flex-wrap">
  <button
    class="filter-btn text-sm uppercase font-bold cursor-pointer group-data-[variant=yellow]:text-black group-data-[variant=light]:text-black"
    data-filter="all"
  >
    All
  </button>
  {
    categories.map((c) => (
      <button
        class="filter-btn text-sm text-muted-foreground cursor-pointer transition-all duration-200 group-data-[variant=yellow]:text-black group-data-[variant=light]:text-black"
        data-filter={c.slug}
      >
        {c.title}
      </button>
    ))
  }
</div>

<GridContainer class="pt-4 pb-8">
  {
    entries.map((entry) => (
      <div
        class="col-span-2"
        data-categories={entry.categories.map((c) => c.slug).join(",")}
      >
        {baseHref === "/work" ? (
          <WorkCard
            cover={entry.cover}
            title={entry.title}
            href={`${baseHref}/${entry.slug}`}
            category={entry.categories.map((c) => c.title).join(", ")}
            publishedAt={entry.publishedAt}
          />
        ) : (
          <NoteCard
            title={entry.title}
            href={`${baseHref}/${entry.slug}`}
            category={entry.categories.map((c) => c.title).join(", ")}
            publishedAt={entry.publishedAt}
            author={entry.author}
          />
        )}
      </div>
    ))
  }
</GridContainer>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const cards = document.querySelectorAll<HTMLElement>("[data-categories]");
  const activeLabel = document.getElementById("active-label");
  const details = document.querySelector<HTMLDetailsElement>("details");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter!;

      buttons.forEach((b) => {
        b.classList.remove("font-bold", "text-white");
        b.classList.add("text-muted-foreground");
      });
      btn.classList.add("font-bold", "text-white");
      btn.classList.remove("text-muted-foreground");

      cards.forEach((card) => {
        const categories = card.dataset.categories ?? "";
        card.style.display =
          filter === "all" || categories.includes(filter) ? "" : "none";
      });

      if (activeLabel) activeLabel.textContent = btn.textContent;
      if (details) details.open = false;
    });
  });
</script>
